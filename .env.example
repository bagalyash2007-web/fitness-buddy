# .env.example — Fitness Buddy Environment Variables
# ----------------------------------------------------
# Copy this file to ".env" and fill in your real credentials.
# Never commit the .env file to version control.

# IBM Cloud API key (from https://cloud.ibm.com/iam/apikeys)
WATSONX_APIKEY=your_ibm_cloud_api_key_here

# watsonx.ai service URL — use the URL for your IBM Cloud region, e.g.:
#   US South : https://us-south.ml.cloud.ibm.com
#   EU DE    : https://eu-de.ml.cloud.ibm.com
#   JP TOK   : https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Your watsonx.ai project ID (found in your project settings on watsonx.ai)
WATSONX_PROJECT_ID=your_watsonx_project_id_here
